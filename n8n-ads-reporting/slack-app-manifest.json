{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "Ads Reporting Bot",
    "description": "Posts the daily Google + Meta performance digest into Slack."
  },
  "features": {
    "bot_user": {
      "display_name": "Ads Reporting Bot",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": ["chat:write", "incoming-webhook"]
    }
  },
  "settings": {
    "incoming_webhooks": {
      "incoming_webhooks_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false
  }
}
